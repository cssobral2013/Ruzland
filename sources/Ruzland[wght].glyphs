languagesystem latn ROM ; # Latin Romanian
languagesystem latn TRK ; # Latin Turkish
languagesystem cyrl dflt; # Cyrillic default
languagesystem cyrl BSH ; # Cyrillic Bashkir
languagesystem cyrl CHU ; # Cyrillic Chuvash


#
# Lookup definitions
#


#
# Feature definitions
#
";
tag = Languagesystems;
}
);
features = (
{
code = "# Access All Alternates

#> feature
  feature locl;
  feature sinf;
  feature sups;
  feature subs;
  feature numr;
  feature salt;
  feature hist;
  feature case;
#< feature";
tag = aalt;
},
{
code = "# Glyph Composition/Decomposition

#> feature
  sub breve hookabovecomb by breve_hookabovecomb;
  sub circumflex hookabovecomb by circumflex_hookabovecomb;
#< feature";
tag = ccmp;
},
{
code = "# Localized Forms

#> feature
  script latn; # Latin
  language MOL; # Moldavian
  sub Scedilla by Scommaaccent;
  sub Tcedilla by Tcommaaccent;
  sub scedilla by scommaaccent;
  sub tcedilla by tcommaaccent;

  language ROM; # Romanian
  sub Scedilla by Scommaaccent;
  sub Tcedilla by Tcommaaccent;
  sub scedilla by scommaaccent;
  sub tcedilla by tcommaaccent;

  language TRK;
  sub i by i.loclTRK;

    language AZE;
  sub i by i.loclTRK;

    language KAZ;
  sub i by i.loclTRK;
    language CRT;
  sub i by i.loclTRK;
    language TAT;
  sub i by i.loclTRK;

  language NLD;
  sub I J by IJ;
  sub Iacute J' by Jacute.loclNLD;
  sub i j by ij;
  sub iacute j' by jacute.loclNLD;

  language CAT;
  sub L' periodcentered' L by Ldot;
  sub l' periodcentered' l by ldot;

  script cyrl; # Cyrillic
    language BGR ; # Bashkir
    sub @locl by @locl2;
    language SRB ;
    sub becyr by becyr.loclSRB;
    language MKD ;
    sub becyr by becyr.loclSRB;

    language BSH ; # Bashkir
    sub [Gestrokecyr gestrokecyr Zetailcyr zetailcyr] by [Gestrokecyr.alt gestrokecyr.alt Zetailcyr.alt zetailcyr.alt];
    sub [Estailcyr estailcyr] by [Estailcyr.alt estailcyr.alt];

    language CHU ; # Chuvash
    sub [Estailcyr estailcyr] by [Estailcyr.alt02 estailcyr.alt02];
#< feature";
tag = locl;
},
{
code = "# Scientific Inferiors

#> feature
  sub four by four.inferior;
  sub one by one.inferior;
  sub three by three.inferior;
  sub two by two.inferior;
#< feature";
tag = sinf;
},
{
code = "# Superscript

#> feature
  sub one by onesuperior;
  sub three by threesuperior;
  sub two by twosuperior;
#< feature";
tag = sups;
},
{
code = "# Subscript

#> feature
  sub four by four.inferior;
  sub one by one.inferior;
  sub three by three.inferior;
  sub two by two.inferior;
#< feature";
tag = subs;
},
{
code = "# Numerator

#> feature
  sub one by one.numerator;
#< feature";
tag = numr;
},
{
code = "# Fractions

#> feature
lookup frac_precomposed {

  sub one slash four by onequarter;
  sub one slash two by onehalf;
  sub three slash four by threequarters;
  sub one fraction four by onequarter;
  sub one fraction two by onehalf;
  sub three fraction four by threequarters;
} frac_precomposed;
#< feature";
tag = frac;
},
{
code = "# Ordinals

#> feature
  sub [zero one two three four five six seven eight nine] [A a]' by ordfeminine;
  sub [zero one two three four five six seven eight nine] [O o]' by ordmasculine;
  sub N o period by numero;
#< feature";
tag = ordn;
},
{
code = "# Stylistic Alternates

#> feature
  sub Estailcyr from [Estailcyr.alt02 Estailcyr.alt];
  sub Gestrokecyr from [Gestrokecyr.alt];
  sub Iukrcyr from [Iukrcyr.alt];
  sub Zetailcyr from [Zetailcyr.alt];
  sub estailcyr from [estailcyr.alt02 estailcyr.alt];
  sub fraction from [fraction.alt];
  sub gestrokecyr from [gestrokecyr.alt];
  sub iukrcyr from [iukrcyr.alt];
  sub zetailcyr from [zetailcyr.alt];
#< feature";
tag = salt;
},
{
code = "# Contextual Alternates

#> feature
sub yukrcyr yukrcyr by yukrcyr_yukrcyr.calt;
#< feature";
tag = calt;
},
{
code = "# Discretionary Ligatures

#> feature
  sub breve acute by breve_acute;
  sub breve grave by breve_grave;
  sub breve tilde by breve_tilde;
  sub circumflex acute by circumflex_acute;
  sub circumflex grave by circumflex_grave;
  sub circumflex tilde by circumflex_tilde;
  sub f i by fi;
  sub f l by fl;
#< feature";
tag = dlig;
},
{
code = "# Historical Forms

#> feature
  sub s by longs;
#< feature";
tag = hist;
},
{
code = "# Case Sensitive Forms

#> feature
  sub acute by acute.case;
  sub breve by breve.case;
  sub caron by caron.case;
  sub circumflex by circumflex.case;
  sub cyrbreve by cyrbreve.case;
  sub dieresis by dieresis.case;
  sub grave by grave.case;
  sub hungarumlaut by hungarumlaut.case;
  sub macron by macron.case;
  sub tilde by tilde.case;
#< feature";
tag = case;
},
{
code = "# GPOS feature : Mark Positioning
    markClass acute <anchor 221 948> @top;
    markClass acute.case <anchor 341 1365> @top;

  lookup markLTR {
      pos base Iocyr
          <anchor 756 1639> mark @top;
      pos base Eukrcyr
          <anchor 833 1356> mark @top;
      pos base Iukrcyr
          <anchor 438 1356> mark @top;
      pos base Yukrcyr
          <anchor 438 1692> mark @top;
      pos base Acyr
          <anchor 738 1356> mark @top;
      pos base Iecyr
          <anchor 756 1356> mark @top;
      pos base Icyr
          <anchor 835 1356> mark @top;
      pos base Ocyr
          <anchor 835 1356> mark @top;
      pos base Ucyr
          <anchor 781 1356> mark @top;
      pos base Ylongcyr
          <anchor 1081 1365> mark @top;
      pos base Yucyr
          <anchor 1260 1356> mark @top;
      pos base Yacyr
          <anchor 743 1356> mark @top;
      pos base acyr
          <anchor 565 948> mark @top;
      pos base iecyr
          <anchor 494 948> mark @top;
      pos base icyr
          <anchor 647 948> mark @top;
      pos base ocyr
          <anchor 512 948> mark @top;
      pos base ucyr
          <anchor 562 948> mark @top;
      pos base ylongcyr
          <anchor 874 950> mark @top;
      pos base yucyr
          <anchor 792 948> mark @top;
      pos base yacyr
          <anchor 598 948> mark @top;
      pos base iocyr
          <anchor 507 1365> mark @top;
      pos base eukrcyr
          <anchor 514 948> mark @top;
      pos base yukrcyr
          <anchor 282 1356> mark @top;
  } markLTR;

  lookup markLTR;";
tag = mark;
}
